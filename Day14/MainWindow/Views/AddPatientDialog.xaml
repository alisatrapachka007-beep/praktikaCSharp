<Window x:Class="MedicalRecordsApp.Views.AddPatientDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация пациента" Height="500" Width="450"
        WindowStartupLocation="CenterOwner" Background="#F0F4F8">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20">
            <TextBlock Text="ФИО пациента:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="FullNameTextBox" Margin="0,0,0,15"/>

            <TextBlock Text="Возраст:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="AgeTextBox" Margin="0,0,0,15"/>

            <Border BorderBrush="#4A6FA5" BorderThickness="0,0,0,2" Margin="0,10,0,10">
                <TextBlock Text="Первичная медицинская запись" FontWeight="Bold" FontSize="14" 
                           Foreground="#4A6FA5" Padding="0,5"/>
            </Border>

            <TextBlock Text="Диагноз:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="DiagnosisTextBox" Margin="0,0,0,15"/>

            <TextBlock Text="Заметки врача:" FontWeight="Bold" Margin="0,0,0,5"/>
            <TextBox x:Name="NotesTextBox" Height="80" TextWrapping="Wrap"
                     AcceptsReturn="True" Margin="0,0,0,20"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="OK" Width="80" Click="OkButton_Click" Margin="0,0,10,0"/>
                <Button Content="Отмена" Width="80" Click="CancelButton_Click" Background="Gray"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Window>