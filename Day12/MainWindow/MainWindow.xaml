<Window x:Class="MedicalRecordsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Медицинские записи" Height="550" Width="800"
        Background="#F0F4F8">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#4A6FA5"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A5A8C"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="ListBox">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#D0D7DE"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Медицинские записи" FontSize="24" FontWeight="Bold"
                   Foreground="#2C3E50" Margin="0,0,0,15"
                   HorizontalAlignment="Center"/>

        <TabControl Grid.Row="1">
            <TabItem Header="Пациенты и история" Background="#E9EDF2">
                <Grid Margin="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                        <TextBlock Text="Список пациентов" FontWeight="Bold" Margin="0,0,0,5"/>
                        <ListBox x:Name="PatientsListBox" Height="300"
                                 DisplayMemberPath="FullName"
                                 SelectionChanged="PatientsListBox_SelectionChanged"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="История болезни" FontWeight="Bold" Margin="0,0,0,5"/>
                        <DataGrid x:Name="HistoryDataGrid" Height="250"
                                  Margin="0,0,0,10"
                                  AutoGenerateColumns="False">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat='dd.MM.yyyy'}" Width="100"/>
                                <DataGridTextColumn Header="Диагноз" Binding="{Binding Diagnosis}" Width="150"/>
                                <DataGridTextColumn Header="Заметки врача" Binding="{Binding DoctorNotes}" Width="*"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button x:Name="AddRecordButton" Content="Добавить запись" 
                                Width="150" HorizontalAlignment="Right"
                                Click="AddRecordButton_Click"/>
                    </StackPanel>
                </Grid>
            </TabItem>

        </TabControl>
    </Grid>
</Window>