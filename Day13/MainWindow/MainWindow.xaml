<Window x:Class="MedicalRecordsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:MedicalRecordsApp.ViewModels"
        Title="Медицинские записи" Height="600" Width="900"
        Background="#F0F4F8"
        WindowStartupLocation="CenterScreen">

    <Window.InputBindings>
        <KeyBinding Gesture="Ctrl+R" Command="{Binding RegisterPatientCommand}"/>
        <KeyBinding Gesture="Ctrl+E" Command="{Binding EditRecordCommand}"/>
        <KeyBinding Gesture="Del" Command="{Binding DeleteRecordCommand}"/>
    </Window.InputBindings>

    <DockPanel>
        <!-- Главное меню -->
        <Menu DockPanel.Dock="Top" Background="#E9EDF2">
            <MenuItem Header="_Файл">
                <MenuItem Header="_Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="_Пациенты">
                <MenuItem Header="_Регистрация пациента" Command="{Binding RegisterPatientCommand}" InputGestureText="Ctrl+R"/>
            </MenuItem>
            <MenuItem Header="_Записи">
                <MenuItem Header="_Редактировать запись" Command="{Binding EditRecordCommand}" InputGestureText="Ctrl+E"/>
                <Separator/>
                <MenuItem Header="_Удалить запись" Command="{Binding DeleteRecordCommand}" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="_Настройки">
                <MenuItem Header="_О программе" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <!-- Панель инструментов -->
        <ToolBar DockPanel.Dock="Top" Background="#E9EDF2">
            <Button Command="{Binding RegisterPatientCommand}" ToolTip="Регистрация пациента (Ctrl+R)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Записать пациента"/>
                </StackPanel>
            </Button>

            <Separator/>

            <Button Command="{Binding EditRecordCommand}" ToolTip="Редактировать запись (Ctrl+E)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Редактировать запись"/>
                </StackPanel>
            </Button>

            <Button Command="{Binding DeleteRecordCommand}" ToolTip="Удалить запись (Del)">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Удалить запись"/>
                </StackPanel>
            </Button>
        </ToolBar>

        <!-- Основной контент -->
        <Grid Margin="10">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Медицинские записи" FontSize="24" FontWeight="Bold"
                       Foreground="#2C3E50" Margin="0,0,0,15"
                       HorizontalAlignment="Center"/>

            <TabControl Grid.Row="1">
                <TabItem Header="Пациенты и история" Background="#E9EDF2">
                    <Grid Margin="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="2*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Margin="0,0,10,0">
                            <TextBlock Text="Список пациентов" FontWeight="Bold" Margin="0,0,0,5"/>
                            <ListBox ItemsSource="{Binding Patients}"
                                     SelectedItem="{Binding SelectedPatient, UpdateSourceTrigger=PropertyChanged}"
                                     DisplayMemberPath="FullName"
                                     Height="400"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="История болезни" FontWeight="Bold" Margin="0,0,0,5"/>
                            <DataGrid ItemsSource="{Binding CurrentPatientRecords}"
                                      SelectedItem="{Binding SelectedRecord}"
                                      Height="350" Margin="0,0,0,10"
                                      AutoGenerateColumns="False">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat='dd.MM.yyyy'}" Width="100"/>
                                    <DataGridTextColumn Header="Диагноз" Binding="{Binding Diagnosis}" Width="150"/>
                                    <DataGridTextColumn Header="Заметки врача" Binding="{Binding DoctorNotes}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Grid>
                </TabItem>

                <TabItem Header="О программе" Background="#E9EDF2">
                    <StackPanel Margin="20" VerticalAlignment="Center">
                        <TextBlock Text="Медицинские записи - система учета пациентов" 
                                   FontSize="16" TextAlignment="Center" Margin="0,0,0,20"/>
                        <TextBlock Text="Версия 2.0" TextAlignment="Center" 
                                   FontStyle="Italic" Foreground="Gray"/>
                        <TextBlock Text="© 2026" TextAlignment="Center" Margin="0,10,0,0"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>