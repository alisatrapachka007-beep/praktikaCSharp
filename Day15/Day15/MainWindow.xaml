<Window x:Class="Day15.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:Day15.Models"
        xmlns:converters="clr-namespace:Day15.Converters"
        Title="Медицинские записи" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <converters:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVisibility"/>

        <DataTemplate DataType="{x:Type models:Patient}">
            <Border BorderBrush="#ccc" BorderThickness="0,0,0,1" Padding="8">
                <StackPanel>
                    <TextBlock FontWeight="Bold">
                        <Run Text="{Binding FullName}"/>
                        <Run Text=" ("/><Run Text="{Binding Age}"/><Run Text=" лет)"/>
                    </TextBlock>
                    <TextBlock FontSize="11" Foreground="Gray">
                        <Run Text="Диагноз: "/><Run Text="{Binding Diagnosis}"/>
                    </TextBlock>
                    <TextBlock FontSize="10" Foreground="Gray" Text="{Binding LastVisitInfo}"/>
                </StackPanel>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <DockPanel>
        <Menu DockPanel.Dock="Top">
            <MenuItem Header="Файл">
                <MenuItem Header="Выход" Command="{Binding ExitCommand}"/>
            </MenuItem>
            <MenuItem Header="Пациенты">
                <MenuItem Header="Новый пациент" Command="{Binding AddPatientCommand}" InputGestureText="Ctrl+N"/>
            </MenuItem>
            <MenuItem Header="Записи">
                <MenuItem Header="Добавить запись" Command="{Binding AddRecordCommand}" InputGestureText="Ctrl+R"/>
                <MenuItem Header="Редактировать" Command="{Binding EditRecordCommand}" InputGestureText="Ctrl+E"/>
                <MenuItem Header="Удалить" Command="{Binding DeleteRecordCommand}" InputGestureText="Del"/>
            </MenuItem>
            <MenuItem Header="Справка">
                <MenuItem Header="О программе" Click="AboutMenuItem_Click"/>
            </MenuItem>
        </Menu>

        <ToolBar DockPanel.Dock="Top">
            <Button Command="{Binding AddPatientCommand}">Новый пациент</Button>
            <Button Command="{Binding AddRecordCommand}">Добавить запись</Button>
            <Button Command="{Binding EditRecordCommand}">Редактировать</Button>
            <Button Command="{Binding DeleteRecordCommand}">Удалить</Button>
            <Button Command="{Binding RefreshCommand}">Обновить</Button>
        </ToolBar>

        <Grid Margin="10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,10,0">
                <Border Background="#f0f0f0" Padding="8" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Фильтр по дате" FontWeight="Bold"/>
                        <DatePicker SelectedDate="{Binding FilterFromDate}" Margin="0,5,0,5"/>
                        <DatePicker SelectedDate="{Binding FilterToDate}" Margin="0,5,0,5"/>
                        <Button Command="{Binding ClearFilterCommand}">Сбросить</Button>
                    </StackPanel>
                </Border>

                <TextBlock Text="Пациенты" FontWeight="Bold" Margin="0,0,0,5"/>

                <Border Background="White" Padding="10" Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True" Height="15"/>
                </Border>

                <ListBox ItemsSource="{Binding Patients}"
                         SelectedItem="{Binding SelectedPatient}"
                         Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibility}}"/>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <Border Background="#f0f0f0" Padding="10" Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Карточка пациента" FontWeight="Bold" FontSize="14"/>
                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="80"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Text="ФИО:" Grid.Row="0" Grid.Column="0"/>
                            <TextBox Text="{Binding SelectedPatient.FullName, Mode=TwoWay}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,5"/>
                            <TextBlock Text="Возраст:" Grid.Row="1" Grid.Column="0"/>
                            <TextBox Text="{Binding SelectedPatient.Age, Mode=TwoWay}" Grid.Row="1" Grid.Column="1" Margin="0,0,0,5"/>
                            <TextBlock Text="Диагноз:" Grid.Row="2" Grid.Column="0"/>
                            <TextBox Text="{Binding SelectedPatient.Diagnosis, Mode=TwoWay}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,5"/>
                        </Grid>
                        <Button Command="{Binding SavePatientChangesCommand}" HorizontalAlignment="Right">Сохранить</Button>
                    </StackPanel>
                </Border>

                <TextBlock Text="История болезни" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>

                <Border Background="White" Padding="10" Visibility="{Binding IsLoadingHistory, Converter={StaticResource BoolToVisibility}}">
                    <ProgressBar IsIndeterminate="True" Height="15"/>
                </Border>

                <DataGrid ItemsSource="{Binding CurrentPatientHistory}"
                          SelectedItem="{Binding SelectedRecord}"
                          Height="250"
                          Visibility="{Binding IsLoadingHistory, Converter={StaticResource InverseBoolToVisibility}}">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Дата" Binding="{Binding Date, StringFormat=dd.MM.yyyy}" Width="100"/>
                        <DataGridTextColumn Header="Диагноз" Binding="{Binding Diagnosis}" Width="150"/>
                        <DataGridTextColumn Header="Заметки" Binding="{Binding DoctorNotes}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </Grid>
    </DockPanel>
</Window>