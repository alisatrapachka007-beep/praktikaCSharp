<Window x:Class="Day15.Views.AddPatientDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Регистрация пациента" Height="480" Width="450"
        WindowStartupLocation="CenterOwner">
	<StackPanel Margin="20">
		<TextBlock Text="ФИО пациента:" FontWeight="Bold" Margin="0,0,0,5"/>
		<TextBox x:Name="FullNameTextBox" Margin="0,0,0,15"/>

		<TextBlock Text="Возраст:" FontWeight="Bold" Margin="0,0,0,5"/>
		<TextBox x:Name="AgeTextBox" Margin="0,0,0,15"/>

		<TextBlock Text="Диагноз (первичный):" FontWeight="Bold" Margin="0,0,0,5"/>
		<TextBox x:Name="DiagnosisTextBox" Margin="0,0,0,15"/>

		<TextBlock Text="Заметки врача:" FontWeight="Bold" Margin="0,0,0,5"/>
		<TextBox x:Name="NotesTextBox" Height="80" TextWrapping="Wrap" AcceptsReturn="True" Margin="0,0,0,20"/>

		<StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
			<Button Content="OK" Width="80" Click="OkButton_Click" Margin="0,0,10,0"/>
			<Button Content="Отмена" Width="80" Click="CancelButton_Click"/>
		</StackPanel>
	</StackPanel>
</Window>